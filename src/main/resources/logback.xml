<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 日志输出路径 -->
    <property name="LOG_HOME" value="logs"/>
    <property name="LOG_FILE" value="flink-cdc"/>

    <!-- ========== Appender - 控制台输出 ========== -->
    <!-- 彩色控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- 详细的日志格式，包含时间、级别、线程、类名、方法等 -->
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36}.%M\(%line\) - %msg%n
            </pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ========== Appender - 文件输出 (所有日志) ========== -->
    <!-- 日志文件输出 - 保留所有日志 -->
    <appender name="FILE_ALL" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${LOG_FILE}-all.log</file>

        <!-- 滚动策略 -->
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- 日志文件名模式 -->
            <fileNamePattern>${LOG_HOME}/${LOG_FILE}-all.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <!-- 每个文件最大 100MB -->
            <maxFileSize>100MB</maxFileSize>
            <!-- 保留 30 天的日志 -->
            <maxHistory>30</maxHistory>
            <!-- 总日志大小不超过 5GB -->
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36}.%M\(%line\) - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ========== Appender - 错误日志文件 ========== -->
    <!-- 只输出 ERROR 和 FATAL 级别的日志 -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${LOG_FILE}-error.log</file>

        <!-- 过滤器 - 只记录 ERROR 级别 -->
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${LOG_FILE}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36}.%M\(%line\) - %msg%n%exception</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ========== Appender - CDC 相关日志 ========== -->
    <!-- 专门记录 CDC 相关的日志 -->
    <appender name="FILE_CDC" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${LOG_FILE}-cdc.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${LOG_FILE}-cdc.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36}.%M\(%line\) - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ========== Appender - 数据处理日志 ========== -->
    <!-- 记录数据转换和处理的详细日志 -->
    <appender name="FILE_DATA" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${LOG_FILE}-data.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${LOG_FILE}-data.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36}.%M\(%line\) - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ========== Appender - 异步控制台输出 ========== -->
    <!-- 使用异步 appender 避免日志输出阻塞应用 -->
    <appender name="ASYNC_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <!-- 队列深度 -->
        <queueSize>512</queueSize>
        <!-- 当队列满时丢弃日志而不是阻塞 -->
        <discardingThreshold>0</discardingThreshold>
        <!-- 引用其他 appender -->
        <appenderRef ref="CONSOLE"/>
    </appender>

    <!-- ========== Logger 配置 ========== -->

    <!-- 您的应用日志 - 最详细 -->
    <logger name="com.stz" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE_ALL"/>
        <appender-ref ref="FILE_DATA"/>
    </logger>

    <!-- Flink 相关日志 -->
    <logger name="org.apache.flink" level="WARN">
        <appender-ref ref="FILE_ALL"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- CDC 相关日志 -->
    <logger name="com.ververica.cdc" level="WARN">
        <appender-ref ref="FILE_CDC"/>
        <appender-ref ref="FILE_ALL"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Debezium 日志 -->
    <logger name="com.github.shyiko.mysql.binlog" level="WARN">
        <appender-ref ref="FILE_CDC"/>
        <appender-ref ref="FILE_ALL"/>
    </logger>

    <!-- MySQL JDBC 驱动日志 -->
    <logger name="com.mysql.cj" level="WARN">
        <appender-ref ref="FILE_DATA"/>
        <appender-ref ref="FILE_ALL"/>
    </logger>

    <!-- FastJSON 日志 -->
    <logger name="com.alibaba.fastjson2" level="WARN">
        <appender-ref ref="FILE_DATA"/>
        <appender-ref ref="FILE_ALL"/>
    </logger>

    <!-- ========== 根 Logger 配置 ========== -->
    <!-- 默认日志级别和 appender -->
    <root level="INFO">
        <!-- 输出到控制台 -->
        <appender-ref ref="CONSOLE"/>
        <!-- 输出到文件 -->
        <appender-ref ref="FILE_ALL"/>
         <!-- 错误日志单独保存 -->
        <appender-ref ref="FILE_ERROR"/>
    </root>

</configuration>